<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Judul halaman — berubah tergantung halaman yang dibuka -->
    <!-- Kalau tidak ada judul, otomatis pakai 'SIPENGABDIAN' -->
    <title><%= typeof title !== 'undefined' ? title : 'SIPENGABDIAN' %></title>

    <!-- Basecoat UI: library tampilan yang diwajibkan dosen -->
    <!-- Ini yang bikin tampilannya rapi dan bagus -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/basecoat-css@0.5.0/dist/basecoat.min.css">

    <!-- CSS tambahan buatan kita sendiri -->
    <link rel="stylesheet" href="/css/custom.css">
</head>
<body>

    <!-- Navbar: tampil di semua halaman -->
    <%- include('../partials/navbar') %>

    <!-- Flash message: notifikasi sukses/error -->
    <%- include('../partials/flash') %>

    <!-- Konten utama -->
    <!-- Isi setiap halaman akan masuk di sini -->
    <main style="padding: 2rem;">
        <%- body %>
    </main>

    <!-- Footer -->
    <footer style="
        text-align: center;
        padding: 1rem;
        color: gray;
        font-size: 0.8rem;
        border-top: 1px solid #e2e8f0;
        margin-top: 2rem;
    ">
        Sistem Informasi Pengabdian Dosen — Kelompok 13 PWEB B
    </footer>

</body>
</html>