<!-- NAVBAR - Tampil di semua halaman           -->

<nav style="
    background-color: #1e40af;
    padding: 0.75rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
">
    <!-- Nama aplikasi di sebelah KIRI -->
    <!-- Untuk ganti warna tulisan: ubah color: white -->
    <div style="font-weight: bold; font-size: 1.2rem; color: white;">
        🎓 SIPENGABDIAN
    </div>

    <!-- Info user di sebelah KANAN -->
    <div>

        <!-- Kalau user SUDAH login: tampilkan nama + tombol keluar -->
        <% if (typeof user !== 'undefined' && user) { %>

            <span style="color: white; margin-right: 1rem; font-size: 0.9rem;">
                Halo, <strong><%= user.name %></strong>
            </span>

            <!-- Tombol Keluar -->
            <!-- Untuk ganti warna tombol: ubah background-color -->
            <form method="POST" action="/logout" style="display: inline;">
                <button type="submit" style="
                    background-color: white;
                    color: #1e40af;
                    border: none;
                    padding: 0.4rem 1rem;
                    border-radius: 6px;
                    cursor: pointer;
                    font-weight: 600;
                ">
                    Keluar
                </button>
            </form>

        <!-- Kalau user BELUM login: tampilkan tombol masuk -->
        <% } else { %>
            <a href="/login" style="
                background-color: white;
                color: #1e40af;
                padding: 0.4rem 1rem;
                border-radius: 6px;
                font-weight: 600;
                text-decoration: none;
            ">
                Masuk
            </a>
        <% } %>

    </div>
</nav>