<% if (success && success.length) { %>
	<div style="padding:.75rem; background:#d4edda; color:#155724; border:1px solid #c3e6cb; margin-bottom:1rem; border-radius:4px;">
		<%= success[0] %>
	</div>
<% } %>

<% if (error && error.length) { %>
	<div style="padding:.75rem; background:#f8d7da; color:#721c24; border:1px solid #f5c6cb; margin-bottom:1rem; border-radius:4px;">
		<%= error[0] %>
	</div>
<% } %>

<% if (validation && validation.length) { %>
	<div style="padding:.75rem; background:#fff3cd; color:#856404; border:1px solid #ffeeba; margin-bottom:1rem; border-radius:4px;">
		<ul style="margin:0; padding-left:1.2rem;">
			<% validation.forEach(function(v){ %>
				<li><%= v.msg %></li>
			<% }) %>
		</ul>
	</div>
<% } %>
