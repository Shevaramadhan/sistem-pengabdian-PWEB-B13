<!-- HALAMAN 500 - Error Server                 -->
<!-- Muncul kalau ada kesalahan di server       -->

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>500 — Terjadi Kesalahan</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/basecoat-css@0.5.0/dist/basecoat.min.css">
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background-color: #f9fafb;
            margin: 0;
        }
        .kotak {
            text-align: center;
            max-width: 450px;
            padding: 2rem;
        }
    </style>
</head>
<body>
    <div class="kotak">

        <p style="font-size: 5rem; margin: 0;">⚠️</p>

        <h1 style="font-size: 2rem; font-weight: bold; color: #111827; margin-top: 1rem;">
            Terjadi Kesalahan
        </h1>

        <p style="color: gray; margin: 1rem 0; font-size: 0.95rem; line-height: 1.6;">
            Server mengalami masalah.<br>
            Silakan coba lagi nanti.
        </p>

        <!-- Kotak detail error — hanya muncul saat mode development -->
        <!-- Berguna saat debugging, tidak muncul saat production -->
        <% if (typeof message !== 'undefined' && message) { %>
            <div style="
                background-color: #fee2e2;
                border: 1px solid #fca5a5;
                border-radius: 6px;
                padding: 1rem;
                margin: 1rem 0;
                text-align: left;
                font-size: 0.8rem;
                color: #991b1b;
            ">
                <!-- Detail error ditampilkan di sini -->
                <strong>Detail error:</strong><br>
                <%= message %>
            </div>
        <% } %>

        <a href="/" style="
            display: inline-block;
            background-color: #1e40af;
            color: white;
            padding: 0.6rem 1.5rem;
            border-radius: 6px;
            font-weight: 600;
            text-decoration: none;
            margin-top: 0.5rem;
        ">
            Kembali ke Beranda
        </a>

    </div>
</body>
</html>